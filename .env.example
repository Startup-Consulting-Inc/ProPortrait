# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Google Gemini API key — get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-3.1-flash-image-preview

# Optional: comma-separated list of allowed CORS origins (for production)
# CORS_ORIGIN=https://yourapp.com

# App base URL (used for Stripe success/cancel redirect URLs)
APP_URL=http://localhost:3000

# ── Stripe (leave empty until your Stripe account is ready) ──────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SESSION_PRICE_ID=price_...    # $14.99 one-time Session Pass
# STRIPE_PRO_PRICE_ID=price_...        # $19.99/month Pro Studio
# STRIPE_TEAMS_PRICE_ID=price_...      # $99/month Teams

# ── Cloudflare R2 (leave empty to fall back to base64 data URLs) ─────────────
# Get credentials from Cloudflare dashboard → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=proportrait-portraits

# ── Resend email (leave empty to just log captures to console) ───────────────
# Get your key from https://resend.com/api-keys
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=hello@proportrait.ai
# ADMIN_EMAIL=you@yourcompany.com

# ── PostHog analytics (leave empty to disable tracking) ──────────────────────
# Get your key from https://posthog.com/
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ── Sentry error tracking (leave empty to disable) ───────────────────────────
# Get your DSN from https://sentry.io/
# VITE_SENTRY_DSN=https://...@sentry.io/...   # client-side
# SENTRY_DSN=https://...@sentry.io/...        # server-side

# ── App public URL (for share buttons) ───────────────────────────────────────
# VITE_APP_URL=https://proportrait.ai

# ── Firebase (server) ────────────────────────────────────────────────────────
# Needed for Firebase Admin SDK (server-side Auth + Firestore)
# On Cloud Run, ADC uses the attached service account automatically.
# For local dev: run `gcloud auth application-default login`
FIREBASE_PROJECT_ID=portrait-7b01d

# ── Firebase (client) — add to GitHub secrets, not .env.local ────────────────
# Get from Firebase Console → Project Settings → Your apps → Web app
# VITE_FIREBASE_API_KEY=AIza...                    # GitHub secret
# VITE_FIREBASE_AUTH_DOMAIN=portrait-7b01d.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=portrait-7b01d
# VITE_FIREBASE_STORAGE_BUCKET=portrait-7b01d.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789      # GitHub secret
# VITE_FIREBASE_APP_ID=1:123:web:abc               # GitHub secret
